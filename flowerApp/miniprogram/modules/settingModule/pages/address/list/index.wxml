<!--pages/address/list/index.wxml-->

<view class="container address-list">
  <view class="list-warpper" wx:if="{{ addressList.length }}">
    <view wx:for="{{ addressList }}" wx:key="index" class="list-item">
      <van-swipe-cell right-width="{{ 65 }}">
        <van-cell-group border="{{ false }}">
          <view class="list-item-box">
            <view class="info" bindtap="changeAddr" data-item="{{item}}">
              <view class="user-info">
                <text>{{item.name}}</text>
                <text>{{item.phone}}</text>
                <text class="default-tag" wx:if="{{item.isDefault}}">默认</text>
              </view>

              <view class="address-info">
                {{item.province+item.city+item.district+item.address}}
              </view>
            </view>

            <view class="editBtn" bindtap="toEdit" data-addr="{{item}}">
              <van-icon name="edit" size="22px" color="#999" />
            </view>
          </view>
        </van-cell-group>
        <!-- <van-icon name="delete" size="22px" color="#999" /> -->
        <view slot="right" class="van-swipe-cell__right" bindtap="deleteAdd" 
        data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </van-swipe-cell>
    </view>
  </view>

  <van-empty wx:else description="还没有收货地址，快去添加吧～" />

  <view class="footer">
    <view class="btn">
      <navigator url="/modules/settingModule/pages/address/add/index">
        新增地址
      </navigator>
    </view>
  </view>
</view>
